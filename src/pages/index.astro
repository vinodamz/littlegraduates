---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
import gallery from '../data/gallery.json';
import { getCollection } from 'astro:content';
const programs = (await getCollection('programs')).sort((a,b) => a.data.order - b.data.order).slice(0,4);
const posts = (await getCollection('blog')).filter(p => !p.data.draft).sort((a,b) => b.data.date - a.data.date).slice(0,3);
const heroImg = "/media/hero/campus.jpg";
const why = [
  ["🌱","tint-green","Montessori-inspired","Child-led learning, guided by teachers who follow each child's interests."],
  ["🔬","tint-teal","Kreedo curriculum","Backed by science, trusted by 3,500+ schools — proven and practical."],
  ["💛","tint-pink","Caring teachers","Educators who know each child by name, story, and strength."],
  ["🛡️","tint-indigo","Safe, hygienic campus","A bright, secure space in the heart of Kaloor for little explorers."],
  ["🌳","tint-amber","Indoor + outdoor play","Sky, mud, grass, and room to roam — a rare gem in Kochi."],
  ["👫","tint-purple","Small class sizes","1:12 ratio. Every child is seen, heard, and gently guided."],
];
const corners = [
  ["🎵","Music space","Explore rhythm, sound, and movement."],
  ["🎤","Public speaking corner","Build confidence through storytelling."],
  ["🎨","Art & creativity zone","Express ideas through colour and craft."],
  ["🧩","Indoor play area","A safe space for open-ended movement."],
  ["🔍","Sensory & discovery","Hands-on science, puzzles, and exploration."],
  ["🌻","Outdoor garden","Sky, mud, grass — a rare bit of nature in the city."],
];
const testimonials = [
  { quote: "A huge blessing — it made me realize how much a school's methodology and approach shape both a child's and a parent's experience of learning.", name: "Reshma Koruth", role: "Parent of 3" },
  { quote: "The faculty is dedicated and passionate. Teachers are friendly and approachable, making kids feel comfortable.", name: "Adithya Unnikrishnan", role: "Parent" },
  { quote: "Calm, clean, and thoughtfully designed to encourage independent learning. Teachers are patient and well-trained in Montessori methods.", name: "Navajyothy Praveen", role: "Parent" },
];
const faqs = [
  ["What ages does Little Graduates accept?", "We welcome children from 1.5 to 6 years across Playgroup, Nursery, LKG and UKG, plus daycare and afterschool options."],
  ["Where is Little Graduates located?", "Kattayil Road, Near Kaloor, Elamakara, Kochi 682017 — in the heart of the city."],
  ["What is the student-teacher ratio?", "We maintain a 1:12 ratio so every child is seen, heard, and gently guided."],
  ["What curriculum do you follow?", "A Montessori-based 6T curriculum built with Kreedo, fully aligned with NEP 2020 and the NCF."],
  ["Are admissions open for 2026?", "Yes — 2026 admissions are open. Book a free tour or WhatsApp us to begin."],
  ["Do you have outdoor play areas?", "Yes. Sky, mud, grass and room to roam — a rare gem in Kochi."],
];
const galleryImgs = gallery.images.slice(0,6);
---
<Base title="Best Preschool in Kaloor, Kochi - The Little Graduates">
  <link slot="head" rel="preload" as="image" href="/media/hero/campus.webp" type="image/webp" fetchpriority="high" />

  <section class="hero soft-pink">
    <div class="blob" style="width:280px;height:280px;background:var(--orange-soft);left:-80px;top:40px;"></div>
    <div class="blob" style="width:220px;height:220px;background:var(--teal-soft);right:-60px;bottom:-40px;"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="kicker"><span aria-hidden="true">✨</span> Now enrolling 2026</span>
        <h1>A joyful Montessori preschool in the heart of <span class="hl">Kaloor, Kochi</span>.</h1>
        <p class="lead">Kochi's most-loved early learning centre — where every child feels at home. Montessori-based learning, caring teachers, and a vibrant campus. Open for ages 1.5 to 6.</p>
        <div class="hero-btns">
          <a class="btn btn-pink btn-lg" href="/book-a-tour/">Book a free tour</a>
          <a class="btn btn-outline btn-lg" href={site.whatsapp}><span aria-hidden="true">💬</span> WhatsApp us</a>
        </div>
        <div class="pill-row" style="justify-content:flex-start;">
          <span class="pill"><span aria-hidden="true">⭐</span> 5.0 · 74 Google reviews</span>
          <span class="pill"><span aria-hidden="true">👩‍🏫</span> 1:12 ratio</span>
          <span class="pill"><span aria-hidden="true">🧒</span> Ages 1.5–6</span>
        </div>
      </div>
      <div class="hero-media">
        <picture>
          <source srcset="/media/hero/campus.webp" type="image/webp" />
          <img src={heroImg} alt="The Little Graduates campus in Kaloor, Kochi" width="1100" height="935" loading="eager" fetchpriority="high" />
        </picture>
        <div class="hero-badge"><span class="emoji" aria-hidden="true">🎓</span><div><strong>600+</strong><br/>Montessori materials</div></div>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <div class="banner">
        <div>
          <span class="kicker">The best way to decide</span>
          <h2>Come visit. See the school for yourself.</h2>
          <p>Free 30-minute campus tour. Any day, any time that works for you. No sales pitch — just walk through and meet the teachers.</p>
        </div>
        <a class="btn btn-white btn-lg" href="/book-a-tour/">Book a free tour →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container center">
      <span class="kicker amber">About us</span>
      <h2>A warm start. A joyful future.</h2>
      <p class="lead">We believe the early years shape everything that comes next. Our 6T curriculum blends Montessori principles, play-based learning, and hands-on skill building — so every child grows in confidence, curiosity, and kindness.</p>
      <a class="btn btn-outline" href="/about/" style="margin-top:.5rem;">More about us</a>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="center"><span class="kicker">Why parents choose us</span><h2>What makes Little Graduates different</h2></div>
      <div class="grid grid-3" style="margin-top:2.5rem;">
        {why.map(([ico,tint,t,d]) => (
          <div class="card"><div class={`ico ${tint}`} aria-hidden="true">{ico}</div><h3>{t}</h3><p>{d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center"><span class="kicker teal">Programs</span><h2>From first steps to first day of school</h2></div>
      <div class="grid grid-4" style="margin-top:2.5rem;">
        {programs.map(p => (
          <a href={`/programs/${p.id}/`} class="card program-card" style="padding:0;overflow:hidden;">
            {p.data.image && <img src={p.data.image} alt="" width="400" height="260" loading="lazy" style="width:100%;display:block;" />}
            <div style="padding:1.2rem 1.4rem 1.5rem;">
              <span class="ages">{p.data.ages}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.excerpt?.split('\n')[0]?.slice(0,90)}…</p>
            </div>
          </a>
        ))}
      </div>
      <p class="center" style="margin-top:2rem;"><a class="btn btn-outline" href="/programs/">See all programs</a></p>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="center"><span class="kicker amber">A peek inside</span><h2>Moments from our classrooms</h2></div>
      <div class="gallery-grid" style="margin-top:2.5rem;">
        {galleryImgs.map((img,i) => (
          <img src={img.src} alt={img.alt} width="400" height="300" loading="lazy" class={i===0 ? 'g-big' : ''} />
        ))}
      </div>
      <p class="center" style="margin-top:2rem;"><a class="btn btn-outline" href="/gallery/">View the gallery</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center"><span class="kicker teal">Experience corners</span><h2>Spaces designed to delight</h2></div>
      <div class="grid grid-3" style="margin-top:2.5rem;">
        {corners.map(([ico,t,d]) => (
          <div class="card"><div class="ico tint-amber" aria-hidden="true">{ico}</div><h3>{t}</h3><p>{d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="center"><span class="kicker">Parents say</span><h2>Loved by parents across Kochi</h2></div>
      <div class="grid grid-3" style="margin-top:2.5rem;">
        {testimonials.map(t => (
          <div class="card">
            <p class="stars" role="img" aria-label="Rated 5 out of 5 stars">★★★★★</p>
            <p style="color:var(--text);margin:.6rem 0 1rem;">“{t.quote}”</p>
            <p style="margin:0;font-family:var(--font-head);font-weight:700;color:var(--indigo);">{t.name}</p>
            <p class="meta" style="margin:0;">{t.role}</p>
          </div>
        ))}
      </div>
      <p class="center" style="margin-top:1.5rem;"><span class="pill"><span aria-hidden="true">⭐</span> 5.0 · 74 Google reviews</span></p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="center"><span class="kicker amber">Parents ask</span><h2>Frequently asked questions</h2></div>
      <div style="margin-top:2.5rem;">
        {faqs.map(([q,a]) => (
          <details class="faq"><summary>{q}</summary><p>{a}</p></details>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="center" style="margin-bottom:2.5rem;"><span class="kicker">From the blog</span><h2>Tips, stories &amp; Montessori insights</h2></div>
      <div class="grid grid-3">
        {posts.map(p => (
          <a href={`/blog/${p.id}/`} class="card" style="padding:0;overflow:hidden;">
            {p.data.image && <img src={p.data.image} alt="" width="400" height="250" loading="lazy" style="aspect-ratio:16/10;object-fit:cover;width:100%;" />}
            <div style="padding:1.3rem 1.5rem 1.6rem;">
              <p class="meta" style="margin:0 0 .4rem;">{p.data.date.toLocaleDateString('en-IN',{year:'numeric',month:'long',day:'numeric'})}</p>
              <h3 style="color:var(--indigo);">{p.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <div class="banner" style="background:linear-gradient(120deg,var(--teal),var(--indigo));">
        <div>
          <span class="kicker">Visit us</span>
          <h2>Come visit. Learning starts here.</h2>
          <p>2026 admissions are open. Book a tour to see our classrooms, meet our teachers, and feel the difference.</p>
        </div>
        <div class="btn-row">
          <a class="btn btn-white btn-lg" href="/book-a-tour/">Book a tour</a>
          <a class="btn btn-green btn-lg" href={site.whatsapp}>WhatsApp us</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero { padding: 4rem 0 5rem; overflow: hidden; }
    .hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 3rem; align-items: center; position: relative; z-index: 1; }
    .hero-copy .hl { color: var(--pink); }
    .hero-btns { display: flex; gap: .8rem; flex-wrap: wrap; margin: 1.6rem 0 .4rem; }
    .hero-media { position: relative; }
    .hero-media img { border-radius: 32px 32px 90px 32px; box-shadow: var(--shadow); aspect-ratio: 4/3.4; object-fit: cover; width: 100%; }
    .hero-badge { position: absolute; left: -18px; bottom: 26px; background: #fff; border-radius: 18px; padding: .8rem 1.1rem; box-shadow: var(--shadow); display: flex; align-items: center; gap: .7rem; font-family: var(--font-head); color: var(--indigo); line-height: 1.1; }
    .hero-badge .emoji { font-size: 1.8rem; }
    .hero-badge strong { font-size: 1.3rem; color: var(--pink); }
    .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 150px; gap: 1rem; }
    .gallery-grid img { width: 100%; height: 100%; object-fit: cover; border-radius: 18px; box-shadow: var(--shadow-sm); }
    .gallery-grid .g-big { grid-column: span 2; grid-row: span 2; border-radius: 24px; }
    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
      .hero-media { order: -1; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 130px; }
      .gallery-grid .g-big { grid-column: span 2; }
    }
  </style>
</Base>
