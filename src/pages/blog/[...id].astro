---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => !p.data.draft);
  return posts.map(p => ({ params: { id: p.id }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} - The Little Graduates`} description={post.data.seoDescription ?? post.data.excerpt ?? post.data.title}>
  <article class="section">
    <div class="container prose">
      <p class="kicker">{post.data.categories[0] ?? 'Blog'}</p>
      <h1>{post.data.title}</h1>
      <p class="meta" style="margin:.75rem 0 1.5rem;">{post.data.date.toLocaleDateString('en-IN', { year:'numeric', month:'long', day:'numeric' })}</p>
      {post.data.image && <img src={post.data.image} alt="" style="border-radius:16px;" />}
      {post.data.video && (
        <div style="position:relative;padding-top:56.25%;margin:1.5rem 0;border-radius:16px;overflow:hidden;">
          {/youtube\.com|youtu\.be|vimeo\.com/.test(post.data.video)
            ? <iframe src={post.data.video.replace('watch?v=','embed/').replace('youtu.be/','youtube.com/embed/')} title="video" allowfullscreen style="position:absolute;inset:0;width:100%;height:100%;border:0;"></iframe>
            : <video src={post.data.video} controls style="position:absolute;inset:0;width:100%;height:100%;"></video>}
        </div>
      )}
      <Content />

      <aside class="post-cta" aria-label="Visit Little Graduates">
        <h2>Considering Little Graduates for your child?</h2>
        <p>We're a joyful <a href="/montessori-preschool-kaloor/">Montessori preschool in Kaloor, Kochi</a> for ages 1.5 to 6. The best way to know us is to see a typical day for yourself.</p>
        <div class="post-cta-links">
          <a class="btn btn-pink" href="/book-a-tour/">Book a free school tour</a>
          <a class="btn btn-outline" href="/admissions/">2026 admissions</a>
        </div>
        <p class="post-cta-more">Explore our <a href="/programs/">programmes for ages 1.5 to 6</a>, the <a href="/curriculum/">2026–27 curriculum</a>, our <a href="/fees/">fee structure</a>, or <a href="/daycare-kaloor/">daycare in Kaloor</a>.</p>
      </aside>

      <p style="margin-top:2.5rem;"><a class="btn btn-outline" href="/blog/">← All posts</a></p>
    </div>
  </article>
  <style>
    .post-cta { margin-top: 3rem; padding: 1.8rem 1.8rem 2rem; border-radius: 18px;
      background: linear-gradient(135deg, #fff5f8, #fff9f0); border: 1px solid rgba(229,68,125,.16); }
    .post-cta h2 { margin: 0 0 .5rem; font-size: 1.3rem; color: var(--indigo); }
    .post-cta > p { margin: 0 0 1.1rem; }
    .post-cta-links { display: flex; gap: .8rem; flex-wrap: wrap; margin-bottom: 1.1rem; }
    .post-cta-more { font-size: .95rem; color: var(--indigo); margin: 0 !important; }
  </style>
</Base>
