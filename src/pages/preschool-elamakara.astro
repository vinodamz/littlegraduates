---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';

const heroImg = '/media/hero/campus.jpg';
const mapSrc = 'https://www.google.com/maps?q=Kattayil+Road,+Elamakara,+Kochi+682017&output=embed';

const schema = {
  '@context': 'https://schema.org',
  '@type': ['Preschool', 'LocalBusiness'],
  name: 'Little Graduates Early Learning Centre',
  alternateName: 'The Little Graduates',
  url: 'https://thelittlegraduates.in/preschool-elamakara/',
  image: 'https://thelittlegraduates.in/media/hero/campus.jpg',
  telephone: '+919562440111',
  email: 'info@thelittlegraduates.in',
  priceRange: '₹₹',
  description:
    'A joyful Montessori preschool in Elamakara, Kochi for ages 1.5 to 6 — caring teachers, small classes and a vibrant campus on Kattayil Road.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Kattayil Road, Near Kaloor, Elamakara',
    addressLocality: 'Kochi',
    addressRegion: 'Kerala',
    postalCode: '682017',
    addressCountry: 'IN',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 9.9981, longitude: 76.2998 },
  areaServed: ['Elamakara', 'Kaloor', 'Kathrikadavu', 'Palarivattom', 'Kochi'],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:30',
    closes: '18:00',
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '5.0', reviewCount: '74' },
};
---
<Base
  title="Montessori Preschool in Elamakara | Little Graduates"
  description="A joyful Montessori preschool in Elamakara, Kochi for ages 1.5 to 6 — caring teachers, small classes and a vibrant campus on Kattayil Road. Book a free tour."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <section class="page-band amber">
    <div class="container">
      <span class="kicker amber">Elamakara · Kochi</span>
      <h1>A joyful Montessori preschool in Elamakara, Kochi</h1>
      <p class="lead">Little Graduates is right here in Elamakara, on Kattayil Road near Kaloor — a warm, play-based Montessori preschool for children aged 1.5 to 6. The closest joyful start for families in Elamakara.</p>
      <div style="display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap;margin-top:1.2rem;">
        <a class="btn btn-pink btn-lg" href="/book-a-tour/">Book a free tour</a>
        <a class="btn btn-outline btn-lg" href={site.phoneHref}>Call {site.phone}</a>
        <a class="btn btn-outline btn-lg" href={site.whatsapp}>WhatsApp us</a>
      </div>
      <div class="pill-row">
        <span class="pill">★ 5.0 · 74 Google reviews</span>
        <span class="pill">1:12 ratio</span>
        <span class="pill">Ages 1.5–6</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2" style="align-items:center;">
      <div>
        <span class="kicker amber">Your neighbourhood preschool</span>
        <h2>Montessori, minutes from home in Elamakara</h2>
        <p>For Elamakara families, the school run shouldn't be a trek across the city. Our campus on Kattayil Road is right in the neighbourhood — and inside, children learn the Montessori way: hands-on, child-led and unhurried, with teachers who know every child by name.</p>
        <p style="margin-bottom:0;"><a class="btn btn-pink" href="/about/">More about us</a></p>
      </div>
      <div>
        <img src={heroImg} width="1100" height="935" loading="lazy"
          alt="Children at The Little Graduates Montessori preschool in Elamakara, Kochi"
          style="border-radius:24px;box-shadow:var(--shadow);width:100%;" />
      </div>
    </div>
  </section>

  <section class="section soft-pink">
    <div class="container grid grid-2" style="align-items:start;gap:2.5rem;">
      <div>
        <span class="kicker teal">Visit us in Elamakara</span>
        <h2>Come see a Montessori morning</h2>
        <p>Find us on Kattayil Road, near Little Flower Church, Pottakuzhi — minutes from anywhere in Elamakara and Kaloor.</p>
        <p class="meta" style="line-height:1.9;">
          {site.address.map((l) => <>{l}<br/></>)}
          <br/>
          <strong>Phone:</strong> <a href={site.phoneHref}>{site.phone}</a><br/>
          <strong>Hours:</strong> Mon–Sat, 9:30 am – 6:00 pm
        </p>
        <p>Need full-day care? See our <a href="/daycare-kaloor/">daycare in Kaloor</a>.</p>
        <p><a class="btn btn-pink" href="/book-a-tour/">Book a free tour</a></p>
      </div>
      <div style="border-radius:18px;overflow:hidden;box-shadow:var(--shadow-sm);">
        <iframe title="Little Graduates location in Elamakara, Kochi" src={mapSrc} width="100%" height="360" style="border:0;display:block;" loading="lazy"></iframe>
      </div>
    </div>
  </section>
</Base>
