---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const programs = (await getCollection('programs')).sort((a,b) => a.data.order - b.data.order);
---
<Base title="Programs - The Little Graduates" description="Playgroup, Nursery, LKG, UKG, daycare and afterschool programs for ages 1.5 to 6 in Kaloor, Kochi.">
  <section class="page-band teal">
    <div class="container"><span class="kicker teal">Programs</span><h1>From first steps to first day of school</h1><p class="lead">Montessori Levels 0–3 for ages 1.5 to 6 — see <a href="/curriculum/">what your child learns at each level</a>.</p></div>
  </section>
  <section class="section">
    <div class="container">
      <div class="grid grid-3" style="margin-top:0;">
        {programs.map(p => (
          <a href={`/programs/${p.id}/`} class="card program-card" style="padding:0;overflow:hidden;text-decoration:none;">
            {p.data.image && <img src={p.data.image} alt="" loading="lazy" style="width:100%;display:block;" />}
            <div style="padding:1.2rem 1.4rem 1.5rem;">
              {p.data.level !== undefined && <span class="level-badge">Level {p.data.level}</span>}<span class="ages">{p.data.ages}</span>
              <h3>{p.data.title}</h3>
              <p style="color:var(--muted);margin:.3rem 0 0;font-size:.95rem;">{p.data.excerpt?.split('\n')[0]?.slice(0,90)}…</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    <section class="container" style="margin:2rem auto 0;">
    <div class="banner">
      <div><p class="kicker">Fees &amp; admissions</p><h2>Planning for 2026?</h2><p>Request the fee structure and admission steps.</p></div>
      <a class="btn btn-white" href="/fees/">Request fee details →</a>
    </div>
  </section>
</Base>
