---
import site from '../data/site.json';
import '../styles/global.css';
const { title = site.name, description = "A joyful Montessori preschool in the heart of Kaloor, Kochi. Ages 1.5 to 6." } = Astro.props;
const nav = [
  ['Home', '/'],
  ['About', '/about/'],
  ['Programs', '/programs/'],
  ['Gallery', '/gallery/'],
  ['Videos', '/videos/'],
  ['Blog', '/blog/'],
  ['Events', '/events/'],
  ['Contact', '/contact/'],
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/media/logo.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preload" href="/media/fonts/nunito.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/media/fonts/baloo2.woff2" as="font" type="font/woff2" crossorigin />
  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src={site.logo} alt={site.name} width="50" height="50" />
        <span>{site.name}</span>
      </a>
      <input type="checkbox" id="nav-toggle" hidden />
      <label for="nav-toggle" class="nav-burger" aria-label="Menu"><span aria-hidden="true">☰</span></label>
      <nav>
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
        <a href="/book-a-tour/" class="btn btn-pink nav-cta">Book a Tour</a>
      </nav>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <div class="brand foot-brand">
          <img src={site.logo} alt={site.name} width="46" height="46" />
          <span>{site.name}</span>
        </div>
        <p>A joyful Montessori preschool for ages 1.5 to 6 in Kaloor, Kochi. Where every child feels at home.</p>
        <p class="foot-rating"><span class="stars" role="img" aria-label="Rated 5 out of 5 stars">★★★★★</span> {site.googleReviews}</p>
      </div>
      <div>
        <h3>Explore</h3>
        {nav.map(([label, href]) => <a class="foot-link" href={href}>{label}</a>)}
      </div>
      <div>
        <h3>Visit us</h3>
        <p>{site.address.map(l => <>{l}<br/></>)}</p>
      </div>
      <div>
        <h3>Talk to us</h3>
        <a class="foot-link" href={site.phoneHref}>{site.phone}</a>
        <a class="foot-link" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="foot-link" href={site.whatsapp}>Chat on WhatsApp</a>
        <a class="btn btn-pink" style="margin-top:1rem;" href="/book-a-tour/">Book a free tour</a>
      </div>
    </div>
    <div class="container foot-bottom">
      © {new Date().getFullYear()} {site.name} · <a href="/privacy-policy/">Privacy Policy</a>
    </div>
  </footer>

  <a class="whatsapp-float" href={site.whatsapp} aria-label="WhatsApp us"><span aria-hidden="true">💬</span> WhatsApp us</a>

  <style>
    .site-header { background: rgba(255,250,240,.9); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 40; border-bottom: 1px solid rgba(43,47,119,.07); }
    .header-inner { display: flex; align-items: center; justify-content: space-between; padding: .7rem 0; gap: 1rem; }
    .brand { display: flex; align-items: center; gap: .6rem; color: var(--indigo); font-family: var(--font-head); font-weight: 800; font-size: 1.15rem; }
    .brand img { border-radius: 12px; }
    nav { display: flex; align-items: center; gap: 1.3rem; flex-wrap: wrap; }
    nav a { color: var(--indigo); font-family: var(--font-head); font-weight: 600; font-size: .98rem; transition: color .15s; }
    nav a:hover { color: var(--pink); }
    .nav-cta { color: #fff !important; padding: .55rem 1.3rem; }
    .nav-burger { display: none; font-size: 1.7rem; color: var(--indigo); cursor: pointer; }
    .site-footer { background: var(--indigo); color: #cfd1ec; padding: 3.5rem 0 2rem; margin-top: 4rem; }
    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1.2fr 1.3fr; gap: 2rem; }
    .site-footer h3 { color: #fff; margin-bottom: .9rem; font-size: 1.05rem; }
    .site-footer p { color: #b9bce0; font-size: .95rem; }
    .foot-brand { color: #fff; margin-bottom: .8rem; }
    .foot-link { display: block; color: #cfd1ec; margin-bottom: .5rem; font-size: .95rem; }
    .foot-link:hover { color: #fff; }
    .foot-rating { margin-top: .6rem; }
    .foot-bottom { border-top: 1px solid rgba(255,255,255,.12); margin-top: 2.5rem; padding-top: 1.5rem; text-align: center; color: #9a9dcb; font-size: .9rem; }
    .foot-bottom a { color: #ffd9e6; text-decoration: underline; }
    @media (max-width: 900px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 860px) {
      .nav-burger { display: block; }
      nav { display: none; width: 100%; flex-direction: column; align-items: flex-start; padding: 1rem 0; gap: .9rem; }
      #nav-toggle:checked ~ nav { display: flex; }
      .header-inner { flex-wrap: wrap; }
    }
    @media (max-width: 560px) { .footer-grid { grid-template-columns: 1fr; } }
  </style>
  <script is:inline>
    (function(){
      const els = document.querySelectorAll('.card, .banner, .page-band h1, .gallery-grid img');
      els.forEach(e => e.classList.add('reveal'));
      if (!('IntersectionObserver' in window)) { els.forEach(e=>e.classList.add('in')); return; }
      const io = new IntersectionObserver((ent)=>{
        ent.forEach(x=>{ if(x.isIntersecting){ x.target.classList.add('in'); io.unobserve(x.target); } });
      }, { threshold: .12, rootMargin: '0px 0px -40px 0px' });
      els.forEach((e,i)=>{ e.style.transitionDelay = (Math.min(i%6,5)*40)+'ms'; io.observe(e); });
    })();
  </script>
</body>
</html>
