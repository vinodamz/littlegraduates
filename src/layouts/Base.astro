---
import site from '../data/site.json';
import '../styles/global.css';
const { title = site.name, description = "A joyful Montessori preschool in the heart of Kaloor, Kochi. Ages 1.5 to 6." } = Astro.props;
const nav = [
  ['Home', '/'],
  ['About', '/about/'],
  ['Programs', '/programs/'],
  ['Gallery', '/gallery/'],
  ['Blog', '/blog/'],
  ['Events', '/events/'],
  ['Contact', '/contact/'],
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/media/logo.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src={site.logo} alt={site.name} width="64" height="64" />
        <span>{site.name}</span>
      </a>
      <input type="checkbox" id="nav-toggle" hidden />
      <label for="nav-toggle" class="nav-burger" aria-label="Menu">☰</label>
      <nav>
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
        <a href="/book-a-tour/" class="btn btn-pink nav-cta">Book a Tour</a>
      </nav>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="container grid grid-3">
      <div>
        <h3>{site.name}</h3>
        <p>{site.tagline} — a joyful Montessori preschool for ages 1.5 to 6 in Kaloor, Kochi.</p>
      </div>
      <div>
        <h3>Visit us</h3>
        <p>{site.address.map(l => <>{l}<br/></>)}</p>
      </div>
      <div>
        <h3>Talk to us</h3>
        <p>
          <a href={site.phoneHref}>{site.phone}</a><br/>
          <a href={`mailto:${site.email}`}>{site.email}</a><br/>
          <a href={site.whatsapp}>Chat on WhatsApp</a>
        </p>
      </div>
    </div>
    <div class="container center meta" style="padding-top:2rem;">
      © {new Date().getFullYear()} {site.name} · <a href="/privacy-policy/">Privacy Policy</a>
    </div>
  </footer>

  <a class="whatsapp-float" href={site.whatsapp} aria-label="Chat on WhatsApp">💬 WhatsApp us</a>

  <style>
    .site-header { background: var(--cream); position: sticky; top: 0; z-index: 40; border-bottom: 1px solid rgba(45,50,130,.08); }
    .header-inner { display: flex; align-items: center; justify-content: space-between; padding-top: .6rem; padding-bottom: .6rem; gap: 1rem; }
    .brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; color: var(--indigo); font-family: var(--font-head); font-weight: 700; }
    nav { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; }
    nav a { color: var(--indigo); text-decoration: none; font-family: var(--font-head); font-size: .95rem; }
    nav a:hover { color: var(--pink); }
    .nav-cta { color: #fff; padding: .5rem 1.2rem; }
    .nav-burger { display: none; font-size: 1.6rem; color: var(--indigo); cursor: pointer; }
    .site-footer { background: var(--indigo); color: #E8E9F5; padding: 3rem 0 2rem; margin-top: 4rem; }
    .site-footer h3 { color: #fff; margin-bottom: .5rem; }
    .site-footer a { color: #FFD9E6; }
    @media (max-width: 860px) {
      .nav-burger { display: block; }
      nav { display: none; width: 100%; flex-direction: column; align-items: flex-start; padding: 1rem 0; }
      #nav-toggle:checked ~ nav { display: flex; }
      .header-inner { flex-wrap: wrap; }
    }
  </style>
</body>
</html>
